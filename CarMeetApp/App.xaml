<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarMeetApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#93C5FD</Color>
            <Color x:Key="Accent">#F97316</Color>
            <Color x:Key="PageBackground">#111827</Color>
            <Color x:Key="CardBackground">#1F2937</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#E5E7EB</Color>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>

            <Style TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="Stroke" Value="#334155" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="TitleColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
            </Style>

            <Style TargetType="DatePicker">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
            </Style>

            <Style TargetType="TimePicker">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
