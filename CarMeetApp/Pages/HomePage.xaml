<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarMeetApp.Pages.HomePage"
             Title="Home"
             BackgroundColor="#111827">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Car Meet Hub"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label Text="Bine ai venit in Car Meet Hub - locul unde pasiunea pentru masini prinde viata."
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   LineBreakMode="WordWrap" />

            <Label Text="Car Meet Hub aduce impreuna comunitatea auto, oferindu-ti acces rapid la cele mai interesante evenimente, intalniri si experiente dedicate pasionatilor de automobile."
                   FontSize="18"
                   LineBreakMode="WordWrap"
                   TextColor="White" />

            <Label Text="Fie ca vrei sa descoperi ce urmeaza sau sa retraiesti momentele memorabile din intalnirile anterioare, aici ai totul la indemana. Evenimentele trecute au adunat zeci de participanti si masini impresionante, iar cele viitoare promit experiente si mai spectaculoase, locatii atent alese si o comunitate in continua crestere."
                   FontSize="18"
                   LineBreakMode="WordWrap"
                   TextColor="White" />

            <Label Text="Inscrie-te, participa si fa parte dintr-o retea dinamica unde fiecare eveniment este o oportunitate de a impartasi pasiunea pentru masini, de a descoperi modele unice si de a crea conexiuni reale."
                   FontSize="18"
                   LineBreakMode="WordWrap"
                   TextColor="White" />

            <Label Text="Galerie - Ultimele Evenimente"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White" />

            <CollectionView ItemsSource="{Binding LatestEventPhotos}"
                            HeightRequest="210">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1F2937"
                                Padding="8"
                                WidthRequest="240"
                                StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6">
                                <Image Source="{Binding ImageUrl}"
                                       HeightRequest="140"
                                       Aspect="AspectFill" />
                                <Label Text="{Binding Caption}"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="White"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
