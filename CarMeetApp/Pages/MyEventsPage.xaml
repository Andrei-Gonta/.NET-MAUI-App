<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarMeetApp.Pages.MyEventsPage"
             Title="My Events">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            
            <Button Text="Back"
                    BackgroundColor="#374151"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start" />
            <Label Text="My Joined Events"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />

            <CollectionView ItemsSource="{Binding JoinedEvents}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{StaticResource CardBackground}"
                                Padding="12"
                                Margin="0,0,0,10"
                                StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Date, StringFormat='Date: {0:MMM dd, yyyy h:mm tt}'}" />
                                <Label Text="{Binding Location}" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
