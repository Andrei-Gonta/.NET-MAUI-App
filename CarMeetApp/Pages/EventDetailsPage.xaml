<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarMeetApp.Pages.EventDetailsPage"
             Title="Event Details">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Button Text="Back"
                    BackgroundColor="#374151"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start" />

            <Label Text="{Binding FeaturedEvent.Title}"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />

            <Label Text="{Binding FeaturedEvent.Location}"
                   FontSize="16" />

            <Label Text="{Binding FeaturedEvent.Date, StringFormat='Starts: {0:dddd, MMM dd - h:mm tt}'}"
                   FontSize="16"
                   TextColor="{StaticResource TextSecondary}" />

            <Label Text="{Binding FeaturedEvent.Organizer, StringFormat='Organizer: {0}'}"
                   FontSize="16" />

            <BoxView HeightRequest="1" BackgroundColor="#374151" Margin="0,8" />

            <Label Text="About this event"
                   FontAttributes="Bold"
                   FontSize="18" />

            <Label Text="{Binding FeaturedEvent.Description}"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
