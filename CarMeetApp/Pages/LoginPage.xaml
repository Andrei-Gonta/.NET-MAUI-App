<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarMeetApp.Pages.LoginPage"
             Title="Login">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Welcome Back"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />

            <Label Text="Sign in with Firebase. Regular users end with @email.com, admins end with @admin.com."
                   TextColor="#6B7280" />

            <Entry Placeholder="Email" Keyboard="Email" Text="{Binding Email}" />
            <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}" />

            <Button Text="Login"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="10"
                    IsEnabled="{Binding IsNotBusy}"
                    Clicked="OnLoginClicked" />

            <Label Text="{Binding LoginStatus}"
                   TextColor="#047857"
                   FontAttributes="Bold" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
