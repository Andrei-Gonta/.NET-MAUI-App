<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarMeetApp.Pages.AdminAddEventPage"
             Title="Admin Add Event">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            
            <Button Text="Back"
                    BackgroundColor="#6B7280"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start" />
            <Label Text="Add New Event (Admin)"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />

            <Entry Placeholder="Event title" Text="{Binding TitleInput}" />
            <Entry Placeholder="Location" Text="{Binding LocationInput}" />
            <Entry Placeholder="Organizer" Text="{Binding OrganizerInput}" />
            <DatePicker Date="{Binding EventDate}" />
            <TimePicker Time="{Binding EventTime}" />
            <Editor Placeholder="Description" HeightRequest="100" Text="{Binding DescriptionInput}" />

            <Button Text="Add Event"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="10"
                    Clicked="OnAddEventClicked" />

            <Label Text="{Binding StatusMessage}"
                   FontAttributes="Bold"
                   TextColor="#047857" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
