<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarMeetApp.Pages.ParticipantCarPhotosPage"
             Title="Participant Car Photos">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Button Text="Back"
                    BackgroundColor="#374151"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start" />

            <Label Text="{Binding HeaderText}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />

            <CollectionView ItemsSource="{Binding PhotoPaths}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8"
                                Margin="0,0,0,10"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 10">
                            <Image Source="{Binding .}"
                                   HeightRequest="220"
                                   Aspect="AspectFit" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="No car pictures uploaded for this participant."
                   HorizontalOptions="Center"
                   TextColor="{StaticResource TextSecondary}"
                   IsVisible="{Binding HasNoPhotos}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
