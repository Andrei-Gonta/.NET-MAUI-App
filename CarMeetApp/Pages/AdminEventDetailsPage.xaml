<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarMeetApp.Pages.AdminEventDetailsPage"
             Title="Event Participants">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Button Text="Back"
                    BackgroundColor="#374151"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start" />
            
            <Border BackgroundColor="{StaticResource CardBackground}"
                    Padding="16"
                    StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding EventTitle}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                    
                    <Label Text="{Binding EventLocation}"
                           FontSize="16"
                           TextColor="{StaticResource TextSecondary}" />
                    
                    <Label Text="{Binding EventDate}"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                    
                    <Label Text="{Binding EventOrganizer}"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                    
                    <Label Text="{Binding EventDescription}"
                           FontSize="14"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource CardBackground}"
                    Padding="12"
                    StrokeShape="RoundRectangle 8">
                <Label Text="{Binding ParticipantsCount}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
            </Border>

            <CollectionView ItemsSource="{Binding Participants}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{StaticResource CardBackground}"
                                Padding="16"
                                Margin="0,4"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding FullName}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                
                                <Label Text="{Binding Email}"
                                       FontSize="14"
                                       TextColor="{StaticResource TextSecondary}" />
                                
                                <Label Text="{Binding PhoneNumber}"
                                       FontSize="14"
                                       TextColor="{StaticResource TextSecondary}" />
                                
                                <Border BackgroundColor="{StaticResource CardBackground}"
                                        Padding="8"
                                        StrokeShape="RoundRectangle 6">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Car Details"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                        
                                        <Label Text="{Binding CarInfo}"
                                               FontSize="14"
                                               TextColor="{StaticResource TextPrimary}" />
                                        
                                        <Label Text="{Binding CarSpecs}"
                                               FontSize="12"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                </Border>
                                
                                <Label Text="{Binding SignUpDate}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />

                                <Button Text="See Car"
                                        BackgroundColor="{StaticResource Accent}"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Clicked="OnSeeCarClicked"
                                        CommandParameter="{Binding}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="No participants have signed up for this event yet."
                   FontSize="16"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasNoParticipants}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
